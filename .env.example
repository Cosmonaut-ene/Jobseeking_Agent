# Jobseeking Agent v2 — Environment Variables

# Required: Google Gemini API key
GEMINI_API_KEY=AIza...

# Optional: Push notifications (Telegram Bot API or compatible webhook)
# For Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_CHAT_ID=

# Scheduler settings
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=9        # Daily run at 9 AM
SCHEDULER_MINUTE=0

# Auto-filter thresholds
HIGH_SCORE_THRESHOLD=0.80   # Score >= 80% → immediate push
MID_SCORE_THRESHOLD=0.70    # Score 70-80% → daily report; < 70% → discard

# Scraper settings
DEFAULT_MAX_JOBS=15
