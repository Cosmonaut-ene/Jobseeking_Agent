/* ── Root layout ───────────────────────────────────────────────────────────── */
Screen {
    layout: horizontal;
}

Sidebar {
    width: 18;
    background: $panel;
    border-right: tall $primary;
    layout: vertical;
}

ContentSwitcher {
    width: 1fr;
    height: 1fr;
}

/* ── Sidebar ────────────────────────────────────────────────────────────────── */
#sidebar-title {
    text-align: center;
    padding: 1 0;
    text-style: bold;
    color: $accent;
    border-bottom: solid $primary;
}

.nav-button {
    width: 100%;
    margin: 0;
    border: none;
    background: transparent;
    text-align: left;
    padding: 0 1;
}

.nav-button:hover {
    background: $boost;
}

/* ── Dashboard ──────────────────────────────────────────────────────────────── */
DashboardScreen {
    layout: vertical;
    padding: 1;
}

#stats-row {
    height: 7;
    padding: 0;
}

.stat-box {
    width: 1fr;
    height: 6;
    border: round $primary;
    align: center middle;
    margin: 0 1;
    layout: vertical;
}

.stat-count {
    text-style: bold;
    color: $accent;
    text-align: center;
    width: 100%;
}

.stat-label {
    text-align: center;
    width: 100%;
    color: $text-muted;
}

/* ── Jobs ────────────────────────────────────────────────────────────────────── */
JobsScreen {
    layout: horizontal;
}

.job-list-panel {
    width: 1fr;
    border-right: tall $primary;
    layout: vertical;
}

.detail-panel {
    width: 2fr;
    padding: 1;
    overflow-y: auto;
    layout: vertical;
}

.action-buttons {
    height: 3;
    padding: 0 1;
}

/* ── Profile ─────────────────────────────────────────────────────────────────── */
ProfileScreen {
    layout: vertical;
    padding: 1;
}

#profile-header {
    height: 3;
    align: left middle;
}

#profile-header Label {
    width: 1fr;
}

.profile-form Label {
    margin-top: 1;
}

.list-col {
    width: 1fr;
    border-right: solid $primary;
    padding-right: 1;
}

.form-col {
    width: 2fr;
    padding-left: 1;
    overflow-y: auto;
}

/* ── Resume wizard ────────────────────────────────────────────────────────────── */
ResumeScreen {
    layout: vertical;
    padding: 1;
}

#wizard {
    width: 1fr;
    height: 1fr;
}

#step1, #step2, #step3 {
    layout: vertical;
    padding: 1;
    overflow-y: auto;
}

#step2 {
    align: center middle;
}

/* ── Settings ────────────────────────────────────────────────────────────────── */
SettingsScreen {
    layout: vertical;
    padding: 1 2;
}

.settings-label {
    margin-top: 1;
}

.settings-row {
    height: 3;
    margin-bottom: 1;
}

.settings-row Input {
    width: 1fr;
}

.settings-row Button {
    width: 8;
    margin-left: 1;
}

#key-status {
    margin-bottom: 1;
}

/* ── Bullet modal ──────────────────────────────────────────────────────────────── */
BulletModal {
    align: center middle;
}

#modal-content {
    width: 80;
    height: auto;
    max-height: 80%;
    background: $surface;
    border: thick $primary;
    padding: 2;
    layout: vertical;
}

#modal-content Label {
    margin-top: 1;
}

#modal-buttons {
    height: 3;
    margin-top: 1;
    align: right middle;
}

#modal-buttons Button {
    margin-left: 1;
}
